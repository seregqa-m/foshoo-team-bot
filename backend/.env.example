# Telegram Bot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Mini App URL (для локальной разработки: cloudflared tunnel --url localhost:3000)
MINI_APP_URL=https://your-tunnel.trycloudflare.com

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_URL=http://127.0.0.1:8000

# Database
DATABASE_URL=sqlite:///./theater_bot.db

# Google Calendar
GOOGLE_CALENDAR_JSON=backend/credentials.json
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
SYNC_INTERVAL_MINUTES=15

# Security
SECRET_KEY=your-secret-key-change-in-production

# Admin
ADMIN_ID=123456789
ADMIN_USERNAME=admin

# Logging
LOG_LEVEL=INFO
