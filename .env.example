# Telegram Bot
BOT_TOKEN="your_bot_token_here"
ADMIN_ID="your_telegram_id"
GROUP_CHAT_ID=-1000000000000

# Mini App URL
MINI_APP_URL=https://app.your-domain.ru

# Google Calendar
GOOGLE_CALENDAR_JSON=backend/credentials.json
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com
SYNC_INTERVAL_MINUTES=15

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id

# Logging
LOG_LEVEL=INFO

# AI Assistant (YandexGPT via Yandex Cloud Foundation Models)
# 1. Создать облачный каталог в console.cloud.yandex.ru
# 2. Активировать Foundation Models
# 3. Создать сервисный аккаунт с ролью ai.languageModels.user
# 4. Создать API-ключ для сервисного аккаунта
YANDEX_API_KEY=
YANDEX_FOLDER_ID=b1g_your_folder_id
YANDEX_GPT_MODEL=yandexgpt/latest
ASSISTANT_ENABLED=true
